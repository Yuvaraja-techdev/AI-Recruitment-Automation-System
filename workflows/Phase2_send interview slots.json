    {
      "parameters": {
        "jsCode": "const slots = [];\n\nfor (let day = 1; day <= 3; day++) {\n\n  const baseDate = new Date();\n  baseDate.setDate(baseDate.getDate() + day);\n\n  const dateStr = baseDate.toLocaleDateString('en-GB', {\n    day: '2-digit',\n    month: 'short',\n    year: 'numeric'\n  });\n\n  const times = [\n    '10:00 AM',\n    '2:00 PM',\n    '4:00 PM'\n  ];\n\n  times.forEach(time => {\n    slots.push(`${dateStr} - ${time}`);\n  });\n}\n\nreturn [\n  {\n    json: {\n      slots: slots.join('\\n')\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
